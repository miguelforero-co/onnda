{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "onnda",
  "version": "1.7.4",
  "identifier": "com.onnda.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "onnda",
        "width": 880,
        "height": 640,
        "resizable": true,
        "visible": true,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "center": true,
        "label": "main",
        "url": "/"
      },
      {
        "label": "widget",
        "url": "/widget",
        "title": "",
        "width": 340,
        "height": 120,
        "visible": false,
        "decorations": false,
        "alwaysOnTop": true,
        "transparent": true,
        "resizable": false,
        "skipTaskbar": true,
        "focus": false,
        "shadow": false
      }
    ],
    "macOSPrivateApi": true,
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/miguelforero-co/onnda/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEUyNUQ5MDY2NUY0RTQ4RDIKUldUU1NFNWZacEJkNHJRQXQyVWZEYW4xMExWN29NNW1IN0dDY0tCYVk4SUJtOGtzNGtHTWo4MUsK"
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "dmg",
      "app"
    ],
    "createUpdaterArtifacts": true,
    "externalBin": [
      "binaries/asr"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0",
      "entitlements": "./entitlements.plist",
      "infoPlist": "./Info.plist"
    },
    "resources": {
      "icons/Assets.car": "Assets.car"
    }
  }
}